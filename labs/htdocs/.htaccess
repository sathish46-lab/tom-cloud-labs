# ----------------------------------------------------------------------
# FIXED PROFESSIONAL ROUTING
# ----------------------------------------------------------------------
RewriteEngine On
RewriteBase /

# Custom 404 Error Handler - Secure against server information disclosure
ErrorDocument 404 /app/error.php

# 1. Force HTTPS - COMMENT THESE OUT TO AVOID REDIRECT LOOPS
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Skip real files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. Authentication Routing
RewriteRule ^signin$ auth/signin.php [L,QSA]
RewriteRule ^signup$ auth/signup.php [L,QSA]
RewriteRule ^logout$ auth/logout.php [L,QSA]

# 4. Intelligent Folder Routing
RewriteCond %{DOCUMENT_ROOT}/auth/$1.php -f
RewriteRule ^([^/]+)$ auth/$1.php [L,QSA]

RewriteCond %{DOCUMENT_ROOT}/app/$1.php -f
RewriteRule ^([^/]+)$ app/$1.php [L,QSA]

RewriteRule ^home$ app/home.php [L,QSA]

# 8. Services Routing
RewriteRule ^services$ app/services.php [L,QSA]

# MySQL
RewriteRule ^services/mysql$ app/services/mysql/dashboard.php [L,QSA]
RewriteRule ^services/mysql/database$ app/services/mysql/database.php [L,QSA]

# PostgreSQL
RewriteRule ^services/postgresql$ app/services/postgresql/dashboard.php [L,QSA]
RewriteRule ^services/postgresql/database$ app/services/postgresql/database.php [L,QSA]

# MongoDB
RewriteRule ^services/mongodb$ app/services/mongodb/dashboard.php [L,QSA]
RewriteRule ^services/mongodb/database$ app/services/mongodb/database.php [L,QSA]

# RabbitMQ
RewriteRule ^services/rabbitmq$ app/services/rabbitmq/dashboard.php [L,QSA]
RewriteRule ^services/rabbitmq/vhost$ app/services/rabbitmq/vhost.php [L,QSA]

# Redis
RewriteRule ^services/redis$ app/services/redis/dashboard.php [L,QSA]

# 3. Quiz Module Routing (AI Powered)
RewriteRule ^quiz/v/([a-f0-9]+)/?$ app/quiz/v.php?hash=$1 [L,QSA]
RewriteRule ^quiz/generate/?$ app/quiz/generate.php [L,QSA]
RewriteRule ^quiz/([a-zA-Z0-9-]+)/(Recent|trending|completed|leaderboard)/([a-zA-Z0-9-]+)/?$ app/quiz/start.php?parent=$1&tab=$2&topic_id=$3 [L,QSA]
RewriteRule ^quiz/([a-zA-Z0-9-]+)/(Recent|trending|completed|leaderboard)/?$ app/quiz/quiz_view.php?id=$1&tab=$2 [L,QSA]
RewriteRule ^quiz/([a-zA-Z0-9-]+)/?$ app/quiz/quiz_view.php?id=$1 [L,QSA]
RewriteRule ^quiz$ app/quiz/quiz_hub.php [L,QSA]

# 7. Learn AI Routing
RewriteRule ^learn$ app/learnAI/dashboard.php [L,QSA]
RewriteRule ^learn/lesson/([^/]+)$ app/learnAI/course_view.php?id=$1 [L,QSA]
RewriteRule ^learn/lesson/([^/]+)/chapter/([^/]+)$ app/learnAI/content.php?id=$2 [L,QSA]

# 5. USER PROFILE ROUTING
RewriteCond %{DOCUMENT_ROOT}/app/account.php -f
RewriteRule ^([a-zA-Z0-9_.-]+)$ app/account.php?username=$1 [L,QSA]

# 6. API ROUTING (Consolidated src/api/)
# Handle requests that already include .php extension
RewriteRule ^api/(.+\.php)$ src/api/$1 [L,QSA]
# Handle extensionless requests
RewriteRule ^api/(.+)$ src/api/$1.php [L,QSA]


# 1. Existing Lab Tabs (Dashboard, Domains, Prefs)
RewriteRule ^labs/(dashboard|domains|preferences)/([a-f0-9]{32})$ app/labs/$1.php [L,QSA]

# ------------------------------------------------------------------
# Challenge Routing — Pattern: /challenges/{tab}/{hash-or-slug}
# ------------------------------------------------------------------

# Redirect /labs/challenges/... to /challenges/... (Compatibility)
RewriteRule ^labs/(challenges|leaderboard|dashboard|achievements)/([a-zA-Z0-9_-]+)$ challenges/$1/$2 [R=301,L]

# Challenge Tabs
# Pattern: /challenges/{tab}/{hash}
RewriteRule ^challenges/(dashboard|challenges|leaderboard|achievements)/([a-f0-9]{32})$ app/challenges/$1.php [L,QSA]

# Pattern: /challenges/{tab}/{slug}
RewriteRule ^challenges/(dashboard|challenges|leaderboard|achievements)/([a-zA-Z0-9_-]+)$ app/challenges/$1.php [L,QSA]

# Global Leaderboard Fallback
RewriteRule ^leaderboard/([a-f0-9]{32})$        app/challenges/leaderboard.php [L,QSA]
RewriteRule ^leaderboard/([a-zA-Z0-9_-]+)$      app/challenges/leaderboard.php [L,QSA]