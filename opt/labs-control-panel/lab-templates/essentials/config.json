{
  "lab_name": "Tom Essentials Lab",
  "lab_id": "essentials",
  "version": 1.0,
  "stability": "beta",
  "resources": {
    "memory": "2g",
    "cpus": "0.5",
    "pids_limit": 100
  },
  "network": {
    "hostname": "essentials",
    "exposed_ports": []
  },
  "storage": {
    "mount_target": "/home/{user}"
  },
  "scripts": {
    "linkuser": "/var/labsdata/scripts/linkuser.sh",
    "entry": "/var/labsdata/scripts/entry.sh"
  },
  "services": {
    "code": { "port": 8080, "middlewares": ["code-headers@file"] },
    "web":  { "port": 80 }
  },
  "credentials_template": {
    "code_server_pass": "{password}",
    "su_pass": "{su_pass}"
  }
}
