{
    "lab_name": "n8n Workflow Lab",
    "lab_id": "n8n",
    "version": 1.0,
    "stability": "beta",
    "resources": {
        "memory": "1.5g",
        "cpus": "0.5",
        "pids_limit": 80
    },
    "network": {
        "hostname": "n8n",
        "exposed_ports": [
            "5678",
            "8080",
            "80",
            "22"
        ]
    },
    "storage": {
        "mount_target": "/home/{user}"
    },
    "scripts": {
        "linkuser": "/var/labsdata/scripts/linkuser.sh",
        "entry": "/var/labsdata/scripts/entry.sh"
    },
    "services": {
        "code": { "port": 8080, "middlewares": ["code-headers@file"] },
        "web":  { "port": 80 },
        "n8n":  { "port": 5678, "domain_flag": "n8n-domain", "domain_prefix": "n8n-" }
    },
    "credentials_template": {
        "n8n_username": "{email}",
        "n8n_password": "{password}",
        "n8n_url": "https://{n8n_domain}",
        "n8n_port": 5678
    }
}